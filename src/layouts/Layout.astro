---
interface Props {
  title: string;
  description?: string;
  keywords?: string;
}

const {
  title,
  description = "Veta - Soluciones tecnológicas disruptivas. Transformamos ideas en realidades digitales.",
  keywords = "desarrollo web, diseño UX, aplicaciones móviles, SaaS, fintech, blockchain, IA, Venezuela",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/og-image.svg", Astro.site);
const siteUrl = "https://veta.tech";
const pagePath = Astro.url.pathname;
const isHomePage = pagePath === "/";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Veta" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript
      ><link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap"
      /></noscript
    >

    <title>{title} | Veta</title>

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Veta`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_VE" />
    <meta property="og:site_name" content="Veta" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Veta`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="geo.region" content="VE" />
    <meta name="geo.placename" content="Venezuela" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Veta",
      "url": siteUrl,
      "description": "Soluciones tecnológicas que rompen barreras",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${siteUrl}/?q={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    })} />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Veta",
      "url": siteUrl,
      "logo": `${siteUrl}/favicon.png`,
      "description": "Soluciones tecnológicas que rompen barreras. Diseño disruptivo, código de élite, resultados que impactan.",
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "sales",
        "url": "https://api.whatsapp.com/send/?phone=584125775296"
      },
      "sameAs": [
        "https://api.whatsapp.com/send/?phone=584125775296"
      ]
    })} />

    {!isHomePage && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Inicio",
            "item": siteUrl
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": title,
            "item": canonicalURL.toString()
          }
        ]
      })} />
    )}
  </head>
  <body class="bg-dark text-white font-body antialiased">
    <a
      href="#main-content"
      class="visually-hidden focus:not-visually-hidden focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-primary focus:text-dark focus:font-semibold focus:rounded-lg"
    >
      Saltar al contenido principal
    </a>
    <slot />
  </body>
</html>
