---
const currentYear = new Date().getFullYear();

const footerLinks = [
  { label: "Inicio", href: "/" },
  { label: "Trabajo", href: "/work" },
  { label: "Planes", href: "/#planes" },
];

const socialLinks = [
  {
    label: "GitHub",
    href: "#",
    icon: "M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z",
  },
  {
    label: "Twitter",
    href: "#",
    icon: "M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z",
  },
  {
    label: "LinkedIn",
    href: "#",
    icon: "M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z M4 6a2 2 0 100-4 2 2 0 000 4z",
  },
];
---

<footer
  class="relative bg-darker border-t border-primary/20 py-16 overflow-hidden"
>
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-32 bg-primary/20 rounded-full blur-3xl"
  >
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid md:grid-cols-3 gap-12 mb-12">
      <div>
        <a href="/" class="flex items-center gap-3 mb-4">
          <div
            class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center"
          >
            <span class="font-display font-bold text-xl text-white">V</span>
          </div>
          <span class="font-display font-bold text-2xl tracking-tight"
            >VETA</span
          >
        </a>
        <p class="text-white/40 text-sm max-w-xs">
          Soluciones tecnológicas que rompen barreras. Diseño disruptivo, código
          de élite.
        </p>
      </div>

      <div>
        <h4 class="font-display font-bold text-lg mb-4 text-white">
          Navegación
        </h4>
        <ul class="space-y-2">
          {
            footerLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-white/50 hover:text-accent transition-colors text-sm"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="font-display font-bold text-lg mb-4 text-white">Contacto</h4>
        <a
          href="mailto:hola@veta.tech"
          class="text-primary hover:text-accent transition-colors text-sm block mb-4"
        >
          a
        </a>
        <div class="flex gap-4">
          {
            socialLinks.map((social) => (
              <a
                href={social.href}
                class="w-10 h-10 bg-primary/10 border border-primary/30 rounded-lg flex items-center justify-center hover:bg-primary hover:border-primary transition-all duration-300"
                aria-label={social.label}
              >
                <svg
                  class="w-5 h-5 text-white/70"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d={social.icon} />
                </svg>
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <div
      class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-4"
    >
      <p class="text-white/30 text-sm">
        © {currentYear} Veta. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-2 text-white/30 text-sm">
        <span>Hecho con</span>
        <svg
          class="w-4 h-4 text-red-500"
          fill="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
          ></path>
        </svg>
        <span>desde el futuro</span>
      </div>
    </div>
  </div>
</footer>
