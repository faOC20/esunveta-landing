---

<footer
  class="relative bg-darker border-t border-primary/20 py-16 overflow-hidden"
>
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-32 bg-primary/20 rounded-full blur-3xl"
  >
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="flex justify-center gap-12 mb-12">
      <div class="flex flex-col">
        <a href="/" class="flex justify-center items-center gap-3 mb-4">
          <Image
            src={logotipo}
            alt="Logotipo de Veta"
            class="w-auto h-6 object-contain"
          />
        </a>
        <p class="text-white/60 text-sm max-w-xs mb-4">
          Soluciones tecnológicas que rompen barreras.
        </p>
        <div class="flex gap-4 justify-center">
          {
            socialLinks.map((social) => (
              <a
                href={social.href}
                target="_blank"
                class="w-10 h-10 bg-primary/10 border border-primary/30 rounded-lg flex items-center justify-center hover:bg-primary hover:border-primary transition-all duration-300"
                aria-label={social.label}
              >
                <social.icon />
              </a>
            ))
          }
        </div>
      </div>

