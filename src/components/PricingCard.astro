---
interface Props {
  name: string;
  price: string;
  description: string;
  features: string[];
  highlighted?: boolean;
  tier: "basic" | "advanced" | "pro";
}

const {
  name,
  price,
  description,
  features,
  highlighted = false,
  tier,
} = Astro.props;
---

<div
  class={`
  relative rounded-2xl p-8 transition-all duration-500 hover:scale-105 h-[600px] flex flex-col justify-between
  ${
    highlighted
      ? "bg-gradient-to-br from-primary/20 to-primary/5 border-2 border-accent glow-primary"
      : "card-brutal"
  }
  ${tier === "basic" ? "hover:rotate-1" : ""}
  ${tier === "pro" ? "hover:-rotate-1" : ""}
`}
>
  {
    highlighted && (
      <div class="absolute -top-4 left-1/2 -translate-x-1/2">
        <span class="bg-accent text-dark px-4 py-1 rounded-full text-sm font-bold">
          RECOMENDADO
        </span>
      </div>
    )
  }

  <div class="mb-6">
    <h3
      class={`font-display font-bold text-2xl mb-2 ${highlighted ? "text-accent" : "text-white"}`}
    >
      {name}
    </h3>
    <p class="text-white/60 text-sm">{description}</p>
  </div>

  <div class="mb-8">
    <span class="font-display font-extrabold text-5xl text-white">{price}</span>
    <span class="text-white/40 text-sm"
      >{tier != "basic" ? "+ fee mensual" : ""}</span
    >
  </div>

  <ul class="space-y-4 mb-8">
    {
      features.map((feature) => (
        <li class="flex items-center gap-3">
          <div
            class={`w-5 h-5 rounded-full flex items-center justify-center ${highlighted ? "bg-accent/20" : "bg-primary/20"}`}
          >
            <svg
              class={`w-3 h-3 ${highlighted ? "text-accent" : "text-primary"}`}
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="3"
                d="M5 13l4 4L19 7"
              />
            </svg>
          </div>
          <span class="text-white/70">{feature}</span>
        </li>
      ))
    }
  </ul>

  <a
    href="https://api.whatsapp.com/send/?phone=584125775296"
    target="_blank"
    class={`
      block text-center py-4 rounded-xl font-semibold transition-all duration-300
      ${
        highlighted
          ? "bg-accent hover:bg-accent/90 text-dark hover:scale-105"
          : "bg-primary/20 border border-primary/50 hover:bg-primary hover:border-primary"
      }
    `}
  >
    Comenzar ahora
  </a>

  <div
    class={`absolute top-4 right-4 w-20 h-20 rounded-full blur-3xl opacity-30 ${highlighted ? "bg-accent" : "bg-primary"}`}
  >
  </div>
</div>
