---
import Logo from "../images/logo.svg";
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20"
>
  <div
    class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-accent/5"
  >
  </div>

  <div
    class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/20 rounded-full blur-3xl animate-float"
  >
  </div>
  <div
    class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-accent/10 rounded-full blur-3xl animate-float"
    style="animation-delay: -3s;"
  >
  </div>

  <div
    class="relative z-10 max-w-7xl mx-auto px-6 py-20 grid lg:grid-cols-2 gap-16 items-center"
  >
    <div class="gap-10 flex flex-col col-span-2">
      <!-- <div
        class="items-center gap-2 bg-primary/10 border border-primary/30 px-4 py-2 rounded-full opacity-0 animate-fade-in"
      >
        <span class="w-2 h-2 bg-accent rounded-full animate-pulse"></span>
        <span class="text-sm font-medium text-primary"
          >Soluciones que rompen barreras</span
        >
      </div> -->

      <h1
        class="font-display font-extrabold text-5xl md:text-7xl lg:text-8xl leading-none tracking-tighter opacity-0 animate-slide-up"
      >
        <span class="text-gradient">Soluciones</span>
        <br />
        <span class="text-white">sin límites</span>
      </h1>

      <div class="flex w-full relative">
        <div class="flex flex-col gap-10">
          <p
            class="text-lg md:text-xl text-white/60 max-w-lg opacity-0 animate-slide-up animate-delay-200"
          >
            Construimos soluciones digitales que transforman industrias. Diseño
            disruptivo, código de élite, resultados que impactan.
          </p>

          <div
            class="flex flex-wrap gap-4 opacity-0 animate-slide-up animate-delay-300"
          >
            <a
              href="#planes"
              class="group bg-primary hover:bg-primary/90 px-8 py-4 rounded-lg font-semibold flex items-center gap-3 transition-all duration-300 hover:scale-105 hover:glow-primary"
            >
              Ver planes
              <svg
                class="w-5 h-5 transform group-hover:translate-x-1 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
            <a
              href="/work"
              class="px-8 py-4 rounded-lg font-semibold border border-white/20 hover:border-accent hover:text-accent transition-all duration-300"
            >
              Ver trabajo
            </a>
          </div>

          <div
            class="flex items-center gap-8 pt-8 opacity-0 animate-slide-up animate-delay-400"
          >
            <div>
              <p class="font-display font-bold text-4xl text-primary">+50</p>
              <p class="text-sm text-white/40">Proyectos</p>
            </div>
            <div class="w-px h-12 bg-white/20"></div>

            <div>
              <p class="font-display font-bold text-4xl text-accent">24/7</p>
              <p class="text-sm text-white/40">Soporte</p>
            </div>
          </div>
        </div>
        <!-- <div class="animate-slide-up animate-delay-200 relative">
          <Logo
            class="[transform:rotate(-10deg)] hover:[transform:rotate(-20deg)] transition-transform duration-500 absolute -top-20 left-10 w-80"
          />
        </div> -->
      </div>
    </div>

    <!-- <div class="relative hidden lg:block">
      <div class="absolute inset-0 bg-gradient-to-tr from-primary/30 to-accent/30 rounded-3xl blur-2xl opacity-50" />
      <div class="relative bg-darker border border-primary/30 rounded-3xl p-8 glow-primary">
        <div class="flex items-center gap-2 mb-6">
          <div class="w-3 h-3 rounded-full bg-red-500" />
          <div class="w-3 h-3 rounded-full bg-yellow-500" />
          <div class="w-3 h-3 rounded-full bg-green-500" />
        </div>
        <div class="space-y-4 font-mono text-sm">
          <p class="text-white/40"><span class="text-primary">const</span> <span class="text-accent">veta</span> = {</p>
          <p class="text-white/60 pl-4"><span class="text-primary">misión</span>: <span class="text-accent">"disrumpir"</span>,</p>
          <p class="text-white/60 pl-4"><span class="text-primary">enfoque</span>: <span class="text-accent">"resultados"</span>,</p>
          <p class="text-white/60 pl-4"><span class="text-primary">pasión</span>: <span class="text-accent">"innovación"</span></p>
          <p class="text-white/40">}</p>
        </div>
        <div class="mt-6 flex gap-3">
          <div class="h-2 w-16 bg-primary/50 rounded animate-pulse" />
          <div class="h-2 w-24 bg-accent/50 rounded animate-pulse" style="animation-delay: 0.5s;" />
          <div class="h-2 w-12 bg-primary/30 rounded animate-pulse" style="animation-delay: 1s;" />
        </div>
      </div>
    </div> -->
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
    <a
      href="#planes"
      class="text-white/30 hover:text-primary transition-colors"
    >
      <svg
        class="w-8 h-8"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </a>
  </div>
</section>
