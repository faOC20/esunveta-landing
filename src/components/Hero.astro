  <div
    class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-primary/30 rounded-full blur-[120px] animate-float"
  >
  </div>
  <div
    class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-accent/20 rounded-full blur-[100px] animate-float"
    style="animation-delay: -3s;"
  >
  </div>

  <div
    class="relative z-10 max-w-7xl mx-auto px-6 py-20 grid lg:grid-cols-2 gap-16 items-center"
  >
    <div class="gap-10 flex flex-col col-span-2">
      <h1
        class="font-display font-extrabold text-5xl md:text-7xl lg:text-8xl leading-none tracking-tighter"
      >
        <span class="text-title-gradient block">Soluciones</span>
        <span class="text-title-gradient-reverse block">sin límites</span>
      </h1>

      <div class="flex w-full relative">
        <div class="flex flex-col gap-10">
          <p class="text-lg md:text-xl text-white/60 max-w-lg">
            Construimos soluciones digitales que transforman industrias. Diseño
            disruptivo, código de élite, resultados que impactan.
          </p>

          <div class="flex flex-wrap gap-4">
            <a
              href="#planes"
              class="group bg-primary hover:bg-primary/90 px-8 py-4 rounded-lg font-semibold flex items-center gap-3 transition-all duration-300 hover:scale-105 hover:glow-primary"
            >
              Ver planes
              <svg
                class="w-5 h-5 transform group-hover:translate-x-1 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
            <a
              href="/work"
              class="px-8 py-4 rounded-lg font-semibold border border-white/20 hover:border-accent hover:text-accent transition-all duration-300"
            >
              Ver trabajo
            </a>
          </div>

          <div class="flex items-center gap-8 pt-8">
            <div>
              <p class="font-display font-bold text-4xl text-primary">+50</p>
              <p class="text-sm text-white/40">Proyectos</p>
            </div>
            <div class="w-px h-12 bg-white/20"></div>

            <div>
              <p class="font-display font-bold text-4xl text-accent">24/7</p>
              <p class="text-sm text-white/40">Soporte</p>
            </div>
          </div>
        </div>

        <div class="animate-slide-up animate-delay-200 bg-red-200">
          <Logo
            class="[transform:rotate(-10deg)] hover:[transform:rotate(-20deg)] transition-transform duration-500 absolute -top-20 left-10 w-80"
          />
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
    <a
      href="#planes"
      class="text-white/30 hover:text-primary transition-colors"
    >
      <svg
        class="w-8 h-8"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </a>
  </div>
</section>
