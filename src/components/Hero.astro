---
import topoColors from "../images/aaaa.avif";
import logo from "../images/veta.png";
import Image from "astro/components/Image.astro";
---

<section
  class="relative min-h-screen flex items-center justify-center pt-20 z-100 overflow-hidden"
  id="inicio"
>
  <!-- <div
    class="absolute -bottom-10 right-[30rem] w-[350px] h-[900px] bg-primary/10 rounded-full -rotate-[36deg]"
  >
  </div>

  <div
    class="absolute -bottom-10 right-56 w-[350px] h-[900px] bg-accent/10 rounded-full rotate-[36deg]"
  >
  </div> -->

  <Image
    src={logo}
    alt="Logo de la empresa Veta que contrasta con el fondo del Hero"
    class="w-auto h-[40rem] absolute -bottom-52 right-20 z-2 animate-slide-up animate-delay-300 brightness-[0.2]"
    loading="eager"
  />

  <div class="topo absolute size-full z-10"></div>

  <Image
    src={topoColors}
    alt="Fondo Topografico para el Hero"
    class="absolute size-full object-cover opacity-20 animate-float"
    loading="eager"
  />

  <div
    class="relative z-10 max-w-7xl mx-auto px-6 py-20 grid lg:grid-cols-2 gap-16 items-center"
  >
    <div class="gap-10 flex flex-col col-span-2">
      <h1
        class="font-display font-extrabold text-5xl md:text-7xl lg:text-8xl leading-none tracking-tighter"
      >
        <span class="block animate-fade-in-left font-serif tracking-wide"
          >Soluciones</span
        >
        <span
          class="text-title-gradient-reverse block animate-fade-in-left"
          style="animation-delay: 150ms;">sin límites</span
        >
      </h1>

      <div class="flex w-full relative">
        <div class="flex flex-col gap-10">
          <p
            class="z-100 text-lg md:text-xl text-white/80 max-w-lg animate-fade-in-scale animate-delay-200"
          >
            Construimos soluciones digitales que transforman industrias. Diseño
            disruptivo, código de élite, resultados que impactan.
          </p>

          <div
            class="flex flex-wrap gap-4 animate-fade-in-scale animate-delay-300"
          >
            <a
              href="#planes"
              class="group bg-primary hover:bg-primary/90 px-8 py-4 rounded-lg font-semibold flex items-center gap-3 transition-all duration-300 hover:scale-105 hover:glow-primary"
            >
              Ver planes
              <svg
                class="w-5 h-5 transform group-hover:translate-x-1 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
            <!-- <a
              class="work-btn relative px-8 py-4 rounded-lg font-semibold border border-white/20 transition-all duration-500 overflow-hidden"
              onmouseenter="this.querySelector('span').textContent='Próximamente'; this.classList.add('text-red-500', 'border-red-500'); this.classList.remove('border-white/20');"
              onmouseleave="this.querySelector('span').textContent='Ver trabajo'; this.classList.remove('text-red-500', 'border-red-500'); this.classList.add('border-white/20');"
            >
              <span class="transition-all duration-500">Ver trabajo</span>
            </a> -->
          </div>

          <div
            class="flex items-center gap-8 pt-8 animate-fade-in-scale animate-delay-400"
          >
            <div>
              <p class="font-display font-bold text-4xl text-primary">+50</p>
              <p class="text-sm text-white/40">Proyectos</p>
            </div>
            <div class="w-px h-12 bg-white/20"></div>

            <div>
              <p class="font-display font-bold text-4xl text-accent">24/7</p>
              <p class="text-sm text-white/40">Soporte</p>
            </div>
          </div>
        </div>

        <!-- <img
          src={logo3d.src}
          alt="Logo de la empresa en 3D"
          class="absolute transition-all duration-500 -right-56 animate-slide-up animate-delay-200 aspect-square w-[550px] h-auto"
          style="mask-image: radial-gradient(circle at center, black 50%, transparent 75%); -webkit-mask-image: radial-gradient(circle at center, black 50%, transparent 75%);"
        /> -->
      </div>
    </div>
  </div>

  <div
    class="z-30 absolute bottom-10 left-1/2 -translate-x-1/2 animate-fade-in animate-delay-600"
  >
    <a
      href="#planes"
      aria-label="Navegar hacia planes"
      class="text-white/30 hover:text-primary transition-colors"
    >
      <svg
        aria-hidden="true"
        class="w-8 h-8"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
      </svg>
    </a>
  </div>
</section>

<style>
  .topo {
    box-shadow: inset 0 0 150px 100px #000000;
  }

  .work-btn span {
    display: inline-block;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .work-btn:hover span {
    transform: scale(0.95);
  }
</style>
