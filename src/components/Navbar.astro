---
const navItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Trabajo', href: '/work' },
  { label: 'Planes', href: '/#planes' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-dark/80 backdrop-blur-md border-b border-primary/20">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <div class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center transform group-hover:rotate-12 group-hover:scale-110 transition-all duration-300">
        <span class="font-display font-bold text-xl text-white">V</span>
      </div>
      <span class="font-display font-bold text-2xl tracking-tight">VETA</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="font-medium text-white/70 hover:text-accent transition-colors duration-300 relative group"
        >
          {item.label}
          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-accent transition-all duration-300 group-hover:w-full" />
        </a>
      ))}
    </div>

    <a
      href="mailto:hola@veta.tech"
      class="hidden md:flex items-center gap-2 bg-primary/20 border border-primary/50 px-5 py-2.5 rounded-lg hover:bg-primary hover:border-primary hover:glow-primary transition-all duration-300"
    >
      <span class="font-medium">Contactar</span>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>

    <button id="mobile-menu-btn" class="md:hidden text-white p-2">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="md:hidden hidden bg-dark/95 border-t border-primary/20">
    <div class="px-6 py-6 flex flex-col gap-4">
      {navItems.map((item) => (
        <a href={item.href} class="font-medium text-white/70 hover:text-accent transition-colors py-2">
          {item.label}
        </a>
      ))}
      <a href="mailto:hola@veta.tech" class="bg-primary/20 border border-primary/50 px-5 py-3 rounded-lg text-center font-medium hover:bg-primary transition-all">
        Contactar
      </a>
    </div>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>