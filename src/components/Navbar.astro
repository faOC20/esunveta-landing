---
const navItems = [
  { label: "Inicio", href: "/#inicio" },
  { label: "Trabajo", href: "/work" },
  { label: "Planes", href: "/#planes" },
  { label: "Contáctanos", href: "/#contacto" },
];
import logotipo from "../images/logocompleto.png";
import Image from "astro/components/Image.astro";
---

<nav
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-dark/80 backdrop-blur-md border-b border-primary/20"
  style="max-width: 100vw; overflow-x: hidden;"
>
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <span class="visually-hidden">Veta</span>
      <Image
        src={logotipo}
        alt="Logo de la empresa Veta"
        class="w-auto h-8"
        loading="eager"
      />
    </a>

    <div class="hidden md:flex items-center gap-8">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="font-medium text-white hover:text-accent transition-colors duration-300 relative group"
          >
            {item.label}
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-accent transition-all duration-300 group-hover:w-full" />
          </a>
        ))
      }
    </div>

    <a
      href="https://api.whatsapp.com/send/?phone=584125775296"
      target="_blank"
      class="hidden md:flex items-center gap-2 bg-primary/20 border border-primary/50 px-5 py-2.5 rounded-lg hover:bg-primary hover:border-primary hover:glow-primary transition-all duration-300"
    >
      <span class="font-medium">Contactar</span>
      <svg
        class="w-4 h-4"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    </a>

    <button
      id="mobile-menu-btn"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Abrir menú de navegación"
      class="md:hidden text-white p-2"
    >
      <svg
        aria-hidden="true"
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden hidden bg-dark/95 border-t border-primary/20"
  >
    <div class="px-6 py-6 flex flex-col gap-4">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="font-medium text-white hover:text-accent transition-colors py-2"
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="https://api.whatsapp.com/send/?phone=584125775296"
        target="_blank"
        class="bg-primary/20 border border-primary/50 px-5 py-3 rounded-lg text-center font-medium hover:bg-primary transition-all"
      >
        Contactar
      </a>
    </div>
  </div>
</nav>

<script>
  const menuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  const closeMenu = () => {
    mobileMenu?.classList.add("hidden");
    menuBtn?.setAttribute("aria-expanded", "false");
    menuBtn?.setAttribute("aria-label", "Abrir menú de navegación");
  };

  menuBtn?.addEventListener("click", () => {
    const isExpanded = mobileMenu?.classList.toggle("hidden") === false;
    menuBtn?.setAttribute("aria-expanded", String(isExpanded));
    menuBtn?.setAttribute(
      "aria-label",
      isExpanded ? "Cerrar menú de navegación" : "Abrir menú de navegación",
    );
  });

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });
</script>
