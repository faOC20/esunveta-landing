---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import BentoGrid from "../components/BentoGrid.astro";
import PricingCard from "../components/PricingCard.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const plans = [
  {
    name: "Básico",
    price: "$289",
    description: "Perfecto para freelancers y proyectos pequeños",
    tier: "basic" as const,
    highlighted: false,
    features: [
      "Landing page para tu negocio",
      "Diseño responsive",
      "Soporte garantizado",
      "SEO",
      "Formulario de contacto",
      "Hosting incluido",
    ],
  },
  {
    name: "Avanzado",
    price: "$589",
    description: "Ideal para empresas en crecimiento",
    tier: "advanced" as const,
    highlighted: true,
    features: [
      "Aplicacion web a medida",
      "Diseño custom + animaciones",
      "Sistemas administrativos con bases de datos",
      "SEO avanzado",
      "CMS integrado",
    ],
  },
  {
    name: "Personalizado",
    price: "$???",
    description: "Hagamos lo que quieras, sin límites",
    tier: "pro" as const,
    highlighted: false,
    features: [
      "Automatizaciones en redes sociales",
      "Integraciones con Inteligencia Artificial",
      "Creación de apps móviles",
      "Conexión con APIs externas",
      "Aplicaciones administrativas",
      "Solo ten la mente abierta",
    ],
  },
];

const features = [
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mx-auto mb-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>',
    title: "Rápido",
    desc: "Tiempo de carga mínimo",
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mx-auto mb-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>',
    title: "Diseño",
    desc: "Interfaces que impactan",
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mx-auto mb-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>',
    title: "Seguro",
    desc: "Máxima protección",
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 mx-auto mb-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>',
    title: "Responsive",
    desc: "Funciona en todos lados",
  },
];
---

<Layout
  title="Inicio"
  description="Veta: Soluciones tecnológicas en Venezuela. Desarrollamos apps web, aplicaciones móviles, integraciones con IA y automatizaciones para redes sociales. Transformamos tu negocio con tecnología de vanguardia."
>
  <Navbar />

  <main id="main-content">
    <Hero />

    <section id="planes" class="py-24 px-6 relative">
      <div
        class="absolute bottom-0 left-0 right-0 top-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px]"
      >
      </div>

      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] md:w-[600px] md:h-[600px] bg-primary/10 rounded-full blur-3xl"
      >
      </div>

      <div class="max-w-7xl mx-auto relative z-10">
        <div class="text-center mb-16 opacity-0 animate-fade-in">
          <span
            class="inline-block px-4 py-2 bg-primary/10 border border-primary/30 rounded-full text-sm font-medium text-primary mb-6"
          >
            Nuestros planes
          </span>
          <h2
            class="font-display font-bold text-4xl md:text-6xl text-white mb-4"
          >
            Elige tu <span class="text-gradient">arma</span>
          </h2>
          <p class="text-white/50 text-lg max-w-2xl mx-auto">
            Planes diseñados para cada etapa de tu negocio. Sin compromisos
            ocultos.
          </p>
        </div>

        <BentoGrid cols="grid-cols-1 md:grid-cols-3" gap="gap-8">
          {
            plans.map((plan) => (
              <div
                class="opacity-0 animate-slide-up"
                style={`animation-delay: ${plans.indexOf(plan) * 150}ms`}
              >
                <PricingCard {...plan} />
              </div>
            ))
          }
        </BentoGrid>
      </div>
    </section>

    <section
      id="contacto"
      class="py-24 px-6 bg-darker relative overflow-hidden"
    >
      <div class="absolute inset-0 opacity-10 overflow-hidden">
        <div
          class="absolute top-0 left-0 w-full h-full bg-[linear-gradient(45deg,#478FC4_25%,transparent_25%,transparent_75%,#478FC4_75%)] bg-[length:50px_50px]"
        >
        </div>
      </div>

      <div class="max-w-7xl mx-auto relative z-10">
        <div class="text-center mb-16">
          <h2
            class="font-display font-bold text-4xl md:text-5xl text-white mb-4"
          >
            ¿Por qué <span class="text-gradient">Veta</span>?
          </h2>
          <p class="text-white/50 text-lg max-w-xl mx-auto">
            No somos una agencia más. Somos tu aliado tecnológico.
          </p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {
            features.map((feature, i) => (
              <div
                class="group bg-dark/50 border border-primary/20 rounded-2xl p-8 text-center hover:border-primary hover:glow-primary transition-all duration-500 hover:scale-105"
                style={`animation-delay: ${i * 100}ms`}
              >
                <div class="text-5xl mb-4" set:html={feature.icon} />
                <h3 class="font-display font-bold text-xl text-white mb-2 group-hover:text-accent transition-colors">
                  {feature.title}
                </h3>
                <p class="text-white/40 text-sm">{feature.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="py-24 px-6 relative">
      <div
        class="absolute top-0 right-0 w-96 h-96 bg-accent/10 rounded-full blur-3xl"
      >
      </div>

      <div class="max-w-4xl mx-auto text-center relative z-10">
        <h2
          class="font-display font-extrabold text-4xl md:text-6xl text-white mb-6"
        >
          ¿Listo para <span class="text-gradient">romperla</span>?
        </h2>
        <p class="text-white/50 text-xl mb-10 max-w-2xl mx-auto">
          No esperamos más. El momento de transformar tu presencia digital es
          ahora.
        </p>
        <a
          href="https://api.whatsapp.com/send/?phone=584125775296"
          target="_blank"
          class="inline-flex items-center gap-3 bg-primary hover:bg-primary/90 px-10 py-5 rounded-xl font-bold text-lg transition-all duration-300 hover:scale-105 hover:glow-primary"
        >
          <span>Hablemos</span>
          <svg
            class="w-6 h-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
