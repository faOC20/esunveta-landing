---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const projects = [
  {
    title: 'Nexus Finance',
    category: 'Fintech',
    description: 'Plataforma de gestión de inversiones con dashboards en tiempo real y análisis predictivo.',
    image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&q=80',
    large: true
  },
  {
    title: 'Pulse Medical',
    category: 'Healthcare',
    description: 'App de telemedicina con videollamadas integradas y gestión de citas.',
    image: 'https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=800&q=80'
  },
  {
    title: 'Dark Matter Studio',
    category: 'Creative Agency',
    description: 'Sitio portfolio inmersivo con animaciones WebGL y experiencia 3D.',
    image: 'https://images.unsplash.com/photo-1558591710-4b4a1ae0f04d?w=800&q=80'
  },
  {
    title: 'CryptoVault',
    category: 'Blockchain',
    description: 'Wallet de criptomonedas con integración DeFi y swap atómico.',
    image: 'https://images.unsplash.com/photo-1639762681485-074b7f938ba0?w=800&q=80'
  },
  {
    title: 'Urban Logistics',
    category: 'Logistics',
    description: 'Sistema de tracking en tiempo real con rutas optimizadas por IA.',
    image: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=800&q=80',
    large: true
  },
  {
    title: 'Neural Studio',
    category: 'AI/ML',
    description: 'Dashboard para entrenamiento de modelos de machine learning.',
    image: 'https://images.unsplash.com/photo-1620712943543-bcc4688e7485?w=800&q=80'
  },
];

const stats = [
  { number: '+50', label: 'Proyectos' },
  { number: '12', label: 'Industrias' },
  { number: '98%', label: 'Satisfacción' },
];
---

<Layout title="Trabajo" description="Proyectos realizados por Veta - Soluciones tecnológicas de vanguardia">
  <Navbar />

  <main id="main-content" class="pt-20">
    <section class="py-24 px-6 relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-96 bg-gradient-to-b from-primary/10 to-transparent" />
      <div class="absolute top-1/2 right-0 w-96 h-96 bg-accent/10 rounded-full blur-3xl" />

      <div class="max-w-7xl mx-auto relative z-10">
        <div class="text-center mb-16">
          <span class="inline-block px-4 py-2 bg-primary/10 border border-primary/30 rounded-full text-sm font-medium text-primary mb-6">
            Portfolio
          </span>
          <h1 class="font-display font-extrabold text-5xl md:text-7xl text-white mb-6">
            Nuestro <span class="text-gradient">trabajo</span>
          </h1>
          <p class="text-white/50 text-xl max-w-2xl mx-auto">
            Cada proyecto es una historia de transformación. Explorá lo que somos capaces de crear.
          </p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
          {stats.map((stat) => (
            <div class="text-center p-6 bg-dark/50 border border-primary/20 rounded-xl">
              <p class="font-display font-bold text-4xl text-primary mb-2">{stat.number}</p>
              <p class="text-white/40 text-sm">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="px-6 pb-24 relative">
      <div class="max-w-7xl mx-auto relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-[300px]">
          {projects.map((project, i) => (
            <div class="opacity-0 animate-slide-up" style={`animation-delay: ${i * 100}ms`}>
              <ProjectCard {...project} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24 px-6 bg-darker relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-primary/5 via-transparent to-accent/5" />

      <div class="max-w-4xl mx-auto text-center relative z-10">
        <h2 class="font-display font-bold text-4xl md:text-5xl text-white mb-6">
          ¿Tenés un proyecto en mente?
        </h2>
        <p class="text-white/50 text-xl mb-10">
          Transformamos tu visión en realidad. Hablemos de tu próximo proyecto.
        </p>
        <a
          href="mailto:hola@veta.tech"
          class="inline-flex items-center gap-3 bg-primary hover:bg-primary/90 px-10 py-5 rounded-xl font-bold text-lg transition-all duration-300 hover:scale-105 hover:glow-primary"
        >
          <span>Start project</span>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>